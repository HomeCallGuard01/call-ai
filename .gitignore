.DS_Store
node_modules/
.env
.env.*
# Exception: this is a template with placeholder values only, meant to be
# committed — see docs/LAUNCH_READINESS.md's production-readiness section.
!.env.example
uploads/

# Logs
logs/
*.log

# Database exports/dumps (may contain customer data) — never commit these.
# Named patterns only, not *.sql, so tracked supabase/migrations/*.sql files
# are unaffected.
*.dump
*.dump.sql
*_dump.sql
*_export.csv
*_export.sql
backup*.sql
db-exports/

# Full Supabase backups (schema + data + roles) — data.sql and
# roles-and-policies.sql contain real customer data / cluster role info and
# must never be committed. Ignoring the whole dated backup directory for now
# rather than picking files individually; a schema-only file may be
# deliberately un-ignored and committed later on its own.
backups/

# Supabase CLI local cache (project ref, pooler host — no credentials, but
# still local machine state, not repo content)
supabase/.temp/