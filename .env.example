# Copy this file to .env and fill in real values. Never commit .env itself
# (it's gitignored) — this file must only ever contain placeholder values.

# --- Supabase ---
# Project Settings → API in the Supabase dashboard.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Full database access — server-side only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI ---
# Used for AI call classification (scam/safe screening).
OPENAI_API_KEY=your-openai-api-key

# --- App ---
# The externally-reachable base URL of this app. Used to build Stripe
# Checkout redirect URLs and Supabase email confirmation/reset links.
# In production this MUST be the real https:// domain — the app will
# refuse to start in production if this still resolves to localhost.
APP_URL=http://localhost:3000

# --- Resend ---
# Not currently read by any application code (email sending currently goes
# through Supabase Auth's own built-in email, not Resend directly) — kept
# here as a placeholder in case that changes. Safe to leave unset today.
Resend_API_Key=your-resend-api-key

# --- Stripe ---
# Use test-mode keys (sk_test_.../whsec_...) for local development, live
# keys only in production. See docs/DECISIONS.md and
# docs/releases/2026-07-18_RC1.md for how this project handles test vs
# live Stripe configuration.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PRICE_ID=price_your-price-id
# From `stripe listen` (local dev) or the Stripe Dashboard's webhook
# endpoint settings (production).
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# --- Node environment ---
# Set to "production" when deployed. Controls the cookie Secure flag and
# gates the startup validation that refuses to boot with missing/invalid
# production config (see services/serverConfig.js).
NODE_ENV=development

# --- Twilio ---
# Required for automatic protected-number provisioning
# (services/twilioProvisioning.js, services/twilioClient.js).
# Twilio Console → Account → API keys & tokens.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Required before any UK local number can be purchased — Twilio rejects
# the purchase without a registered Address object on file (see
# docs/launch/KNOWN_ISSUES.md). Leave blank until the registered office
# address decision is made and the corresponding Address object has been
# created in the Twilio Console.
TWILIO_ADDRESS_SID=
